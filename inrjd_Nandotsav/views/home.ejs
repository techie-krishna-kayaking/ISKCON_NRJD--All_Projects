<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In – ISKCON NRJD Judging Portal</title>
    <meta
      name="description"
      content="Sign in to access the ISKCON NRJD Nandotsav 2025 judging platform."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/CSS/home.css" />
  </head>
  <body>
    <div class="login-layout">
      <!-- LEFT PANEL: Branding -->
      <div class="brand-panel">
        <div class="brand-particles" id="brandParticles"></div>
        <div class="brand-content">
          <div class="brand-logos">
            <div class="brand-logo-circle glow-gold">
              <img src="/image/logo-left.jpg" alt="ISKCON Logo" />
            </div>
            <div class="brand-center">
              <img src="/image/central-photo.jpeg" alt="Central Divine" />
            </div>
            <div class="brand-logo-circle glow-green">
              <img src="/image/logo-right.jpg" alt="NRJD Logo" />
            </div>
          </div>
          <h1 class="brand-title">
            <span>ISKCON Magadi Main Road</span>
            <span class="brand-nrjd">NRJD</span>
          </h1>
          <p class="brand-event">Nandotsav 2025</p>
          <p class="brand-tagline">
            Founder – Āchārya:<br />
            <em>His Divine Grace A.C. Bhaktivedanta Swami Prabhupāda</em>
          </p>
          <div class="brand-mantra">
            <span>Hare Krishna</span>
            <span class="mantra-dot">·</span>
            <span>Hare Rama</span>
          </div>
        </div>
      </div>

      <!-- RIGHT PANEL: Login Form -->
      <div class="form-panel">
        <div class="form-card">
          <!-- Logo for mobile -->
          <div class="mobile-brand">
            <div class="mobile-logo">
              <img src="/image/logo-left.jpg" alt="ISKCON" />
            </div>
            <span>ISKCON NRJD · Nandotsav 2025</span>
          </div>

          <div class="form-header">
            <h2>Welcome Back</h2>
            <p>Sign in to access the judging portal</p>
          </div>

          <!-- Error Alert -->
          <% if (error) { %>
          <div class="alert-error" id="loginError">
            <svg
              width="16"
              height="16"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <circle cx="12" cy="12" r="10" />
              <line x1="12" y1="8" x2="12" y2="12" />
              <line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            <%= error %>
          </div>
          <% } %>

          <form class="login-form" action="/login" method="POST" id="loginForm">
            <!-- Username -->
            <div class="field-group">
              <label for="username" class="field-label">Username</label>
              <div class="field-wrap">
                <span class="field-icon">
                  <svg
                    width="16"
                    height="16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                  </svg>
                </span>
                <input
                  type="text"
                  id="username"
                  name="username"
                  class="field-input"
                  placeholder="Enter your username"
                  required
                  autocomplete="username"
                />
              </div>
            </div>

            <!-- Password -->
            <div class="field-group">
              <label for="password" class="field-label">Password</label>
              <div class="field-wrap">
                <span class="field-icon">
                  <svg
                    width="16"
                    height="16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <rect x="3" y="11" width="18" height="11" rx="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                  </svg>
                </span>
                <input
                  type="password"
                  id="password"
                  name="password"
                  class="field-input"
                  placeholder="Enter your password"
                  required
                  autocomplete="current-password"
                />
                <button
                  type="button"
                  class="toggle-pw"
                  id="togglePw"
                  aria-label="Toggle password visibility"
                >
                  <svg
                    id="eyeIcon"
                    width="16"
                    height="16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                    <circle cx="12" cy="12" r="3" />
                  </svg>
                </button>
              </div>
            </div>

            <!-- Role Selection -->
            <div class="field-group">
              <label class="field-label">I am a</label>
              <div class="role-selector">
                <label class="role-option" id="roleAdmin">
                  <input
                    type="radio"
                    value="Administrator"
                    class="role-radio"
                  />
                  <div class="role-card">
                    <div class="role-icon">
                      <svg
                        width="20"
                        height="20"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                      >
                        <path
                          d="M12 1L3 5V11C3 16.55 6.84 21.74 12 23C17.16 21.74 21 16.55 21 11V5L12 1Z"
                        />
                      </svg>
                    </div>
                    <span>Administrator</span>
                  </div>
                </label>
                <label class="role-option" id="roleJudge">
                  <input type="radio" value="Judge" class="role-radio" />
                  <div class="role-card">
                    <div class="role-icon">
                      <svg
                        width="20"
                        height="20"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                      >
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                      </svg>
                    </div>
                    <span>Judge</span>
                  </div>
                </label>
              </div>
              <!-- Hidden role value submitted with form -->
              <input
                type="hidden"
                name="role"
                id="roleInput"
                value="Administrator"
              />
            </div>

            <button type="submit" class="submit-btn" id="submitBtn">
              <span class="submit-text">Sign In</span>
              <svg
                width="18"
                height="18"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                <polyline points="10 17 15 12 10 7" />
                <line x1="15" y1="12" x2="3" y2="12" />
              </svg>
            </button>
          </form>

          <p class="back-link"><a href="/">← Back to home</a></p>
        </div>
      </div>
    </div>

    <script>
      // ── FIX: Replace the entire <script> block in views/home.ejs with this ───────
      // The bug: clicking a role card that was already selected (or switching back)
      // didn't fire `.change` on the radio because it was already checked.
      // Fix: listen on the `.role-option` wrapper div with a click event,
      // and always force-update regardless of previous state.

      (function () {
        const roleInput = document.getElementById("roleInput");
        if (!roleInput) return;

        // FIX: Use click on the label wrapper (not change on radio)
        document.querySelectorAll(".role-option").forEach(function (option) {
          option.addEventListener("click", function () {
            const radio = option.querySelector(".role-radio");
            if (!radio) return;

            // Force update all state
            document.querySelectorAll(".role-radio").forEach(function (r) {
              r.checked = false;
            });
            document.querySelectorAll(".role-card").forEach(function (c) {
              c.classList.remove("checked");
            });

            radio.checked = true;
            option.querySelector(".role-card").classList.add("checked");
            roleInput.value = radio.value;
          });
        });

        // Set default
        var adminRadio = document.querySelector(
          '.role-radio[value="Administrator"]'
        );
        var adminCard = document.querySelector("#roleAdmin .role-card");
        if (adminRadio) {
          adminRadio.checked = true;
          roleInput.value = "Administrator";
        }
        if (adminCard) {
          adminCard.classList.add("checked");
        }

        // Password toggle
        var pwInput = document.getElementById("password");
        var togglePw = document.getElementById("togglePw");
        var eyeIcon = document.getElementById("eyeIcon");
        if (togglePw && pwInput && eyeIcon) {
          togglePw.addEventListener("click", function () {
            var isText = pwInput.type === "text";
            pwInput.type = isText ? "password" : "text";
            eyeIcon.innerHTML = isText
              ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>'
              : '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
          });
        }

        // Brand particles
        var bp = document.getElementById("brandParticles");
        if (bp) {
          for (var i = 0; i < 18; i++) {
            var p = document.createElement("div");
            p.className = "bp";
            p.style.cssText =
              "left:" +
              Math.random() * 100 +
              "%;width:" +
              (3 + Math.random() * 5) +
              "px;height:" +
              (3 + Math.random() * 5) +
              "px;animation-delay:" +
              Math.random() * 10 +
              "s;animation-duration:" +
              (8 + Math.random() * 12) +
              "s;opacity:" +
              (0.1 + Math.random() * 0.3) +
              ";";
            bp.appendChild(p);
          }
        }
      })();
    </script>
  </body>
</html>
